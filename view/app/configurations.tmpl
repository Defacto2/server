      <div>
        <a href="/f/ac2319e" class="{{$fid}}">ac2319e</a> · 
        <a href="/f/b0269ca" class="{{$fid}}">b0269ca</a> <small>vs</small> <a href="/f/ac1d9d3" class="{{$fid}}">ac1d9d3</a>
