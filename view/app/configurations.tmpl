{{- /* 
    configurations.tmpl ~ Configurations page template.
*/ -}}
{{- define "content" }}
{{- $configs := index . "configurations"}}
{{- $checkDownloads := index . "checkDownloads"}}
{{- $checkPreviews := index . "checkPreviews"}}
{{- $checkThumbnails := index . "checkThumbnails"}}
{{- $checkExtras := index . "checkExtras"}}
{{- $checkOrphaned := index . "checkOrphaned"}}
{{- $extsDownloads := index . "extsDownloads"}}
{{- $extsPreviews := index . "extsPreviews"}}
{{- $extsThumbnails := index . "extsThumbnails"}}
{{- $extsExtras := index . "extsExtras"}}
{{- $extsOrphaned := index . "extsOrphaned"}}
{{- $checkDBConns := index . "dbConnections"}}
{{- $responseRow := "row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-5 g-0"}}
{{- $formats := "badge bg-success text-body-emphasis"}}
{{- /*    */}}
<h2 class="lead mt-5">Database</h2>
<div class="pb-3 text-secondary">
  The number of active connections should always be as low as possible. 
  Having too many connections open are problematic and usually means some SQL queries are waiting to time out.
</div>
<div class="container text-center pb-3">
  <div class="row">
    <div class="col-md-6">
      <button class="btn btn-light w-75" hx-get="/editor/configurations/dbconns" hx-target="#database-response">
        <span class="me-2">&#128907;</span> Refresh the connections <span id="database-htmx-indicator" class="htmx-indicator spinner-border spinner-border-sm ms-2" role="status"></span>
      </button>
    </div>
    <div class="col-md-6">
      <button class="btn btn-light w-75" hx-get="/editor/configurations/pings" hx-target="#ping-response">
        <span class="me-2">&#8634;</span> Ping the routes <span id="ping-htmx-indicator" class="htmx-indicator spinner-border spinner-border-sm ms-2" role="status"></span>
      </button>
    </div>
  </div>
</div>
<div class="p-2 lead">
  <div>{{index . "countPublic"}} public artifacts</div>
  <div class="ps-2"><small class="text-info-emphasis">{{index . "countNewUpload"}} new uploads</small></div>
  <div class="ps-2"><small>{{index . "countHidden"}} unavailable of {{index . "countArtifacts"}}</small></div>
  <div><span id="database-response">{{$checkDBConns}}</span> active database connections</div>
</div>
{{- /*  Ping internal URIs */}}
<h2 class="lead mt-5">Routes</h2>
<div class="pb-3 text-secondary">
  The web application routes runs a stress test that fetches dozens of local URLs to confirm they work.
  <br>
  All the pinged URLs should return <span class="text-success">200</span> HTTP status, 
  except those that require signing in, which returns <span class="text-warning-emphasis">403</span>, <q>the requested resource is forbidden</q>.
</div>
<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-2 p-2" id="ping-response">
  <!-- ping response will be rendered here -->
</div>
{{- /*  Asset counts  */}}
<h2 class="lead mt-5">Web application assets</h2>
<div class="mb-3 text-secondary">
  The web application assets are served to the end users as file downloads, images, or other media. 
  Assets like image previews are available in multiple formats to optimize transfers, such as the original PNG and the newer WEBP. 
  However, the new formats get skipped in odd cases where the newer format offers no file size improvements.
</div>
<div class="table-responsive">
<table class="table align-middle">
  <caption class="p-4">
    Server disk space <b>{{index . "wdUsage"}}</b> of <b>{{index . "wdTotal"}}</b> <small>(usage {{index . "wdPercent"}})</small>
  </caption>
  <thead>
    <tr class="table-secondary">
      <th scope="col" class="fw-light text-center">Asset type</th>
      <th scope="col" class="fw-light">Disk usage</th>
      <th scope="col" class="fw-light text-center">Count</th>
      <th scope="col" class="fw-light">Formats</th>
    </tr>
  </thead>
  <tbody>
    <tr class="table-light">
      <th scope="row" class="fw-light">📥 Downloads</th>
      <td>
        <div><code>{{index . "usageDownloads"}}</code></div>
      </td>
      <td class="text-center"><span class="badge bg-secondary">{{index . "countDownloads"}}</span></td>
      <td>
        {{if ne $checkDownloads nil}}<span class="badge bg-danger-subtle text-danger-emphasis">{{$checkDownloads}}</span>{{- else}}
        <div class="d-flex flex-wrap gap-1">
          {{- range $index, $value := $extsDownloads}}
          <span class="{{$formats}}"><code class="text-uppercase">{{$value.Name}}</code> &nbsp; {{$value.Count}}</span>
          {{- end}}
        </div>
        {{- end}}
      </td>
    </tr>
    <tr class="table-light">
      <th scope="row" class="fw-light">🖼️ Previews</th>
      <td>
        <div><code>{{index . "usagePreviews"}}</code></div>
      </td>
      <td class="text-center"><span class="badge bg-secondary">{{index . "countPreviews"}}</span></td>
      <td>
        {{if ne $checkPreviews nil}}<span class="badge bg-danger-subtle text-danger-emphasis">{{$checkPreviews}}</span>{{- else}}
        <div class="d-flex flex-wrap gap-1">
          {{- range $index, $value := $extsPreviews}}
          <span class="{{$formats}}"><code>{{$value.Name}}</code> &nbsp; {{$value.Count}}</span>
          {{- end}}
        </div>
        {{- end}}
      </td>
    </tr>
    <tr class="table-light">
      <th scope="row" class="fw-light">📷 Thumbnails</th>
      <td>
        <div><code>{{index . "usageThumbnails"}}</code></div>
      </td>
      <td class="text-center"><span class="badge bg-secondary">{{index . "countThumbnails"}}</span></td>
      <td>
        {{if ne $checkThumbnails nil}}<span class="badge bg-danger-subtle text-danger-emphasis">{{$checkThumbnails}}</span>{{- else}}
        <div class="d-flex flex-wrap gap-1">
          {{- range $index, $value := $extsThumbnails}}
          <span class="{{$formats}}"><code>{{$value.Name}}</code> &nbsp; {{$value.Count}}</span>
          {{- end}}
        </div>
        {{- end}}
      </td>
    </tr>
    <tr class="table-light">
      <th scope="row" class="fw-light">📦 Extras</th>
      <td>
        <div><code>{{index . "usageExtras"}}</code></div>
      </td>
      <td class="text-center"><span class="badge bg-secondary">{{index . "countExtras"}}</span></td>
      <td>
        {{if ne $checkExtras nil}}<span class="badge bg-danger-subtle text-danger-emphasis">{{$checkExtras}}</span>{{- else}}
        <div class="d-flex flex-wrap gap-1">
          {{- range $index, $value := $extsExtras}}
          <span class="{{$formats}}"><code>{{$value.Name}}</code> &nbsp; {{$value.Count}}</span>
          {{- end}}
        </div>
        {{- end}}
      </td>
    </tr>
    <tr class="table-light">
      <th scope="row" class="fw-light">🗑️ Orphans</th>
      <td>
        <div><code>{{index . "usageOrphaned"}}</code></div>
      </td>
      <td class="text-center"><span class="badge bg-secondary">{{index . "countOrphaned"}}</span></td>
      <td>
        {{if ne $checkOrphaned nil}}<span class="badge bg-danger-subtle text-danger-emphasis">{{$checkOrphaned}}</span>{{- else}}
        <div class="d-flex flex-wrap gap-1">
          {{- range $index, $value := $extsOrphaned}}
          <span class="{{$formats}}"><code>{{$value.Name}}</code> &nbsp; {{$value.Count}}</span>
          {{- end}}
        </div>
        {{- end}}
      </td>
    </tr>
  </tbody>
</table>
</div>
{{- /*  Links to records  */}}
{{- $confirmed := `<span class="badge bg-success-subtle text-success-emphasis">&#10003;</span>` | safeHTML }}
{{- $fixing := `<span class="badge bg-danger-subtle text-danger-emphasis">&#10005;</span>` | safeHTML }}
{{- $fid := `text-uppercase` }}
<h2 class="lead mt-3">Links to special records</h2>
<div class="mb-3 text-secondary">
  These are highlighted artifacts that have unusual edge cases. 
  <br>Status badges indicate: 
  <span class="badge bg-danger-subtle text-danger-emphasis">&#10005; needs fixing</span> or 
  <span class="badge bg-success-subtle text-success-emphasis">&#10003; confirmed</span>
</div>
<div class="row row-cols-1 row-cols-md-2 g-2">
  <div class="col">
    <div class="p-2 border rounded">
      <div class="mb-2"><strong>CD keys and serials</strong></div>
      <div class="small text-body-secondary mb-2">Readme files with serials and CD keys that should be masked</div>
      <div class="ms-2">
        <a href="/f/b91f23c">1</a> · <a href="/f/c0304ac">2</a> · 
        <a href="/f/ad20232">3</a> · <a href="/f/b023312">4</a> · 
        <a href="/f/af37fc">5</a> · <a href="/f/bd2b294">6</a> · 
        <a href="/f/ba2609c">7</a>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="p-2 border rounded">
      <div class="mb-2"><strong>Broken newlines</strong></div>
      <div class="small text-body-secondary mb-2">Text files with corrupted newline characters due to advertising injection</div>
      <div><a href="/f/b224d50" class="{{$fid}}">b224d50</a> · <a href="/f/ae1c03c" class="{{$fid}}">ae1c03c</a> <span class="small text-muted">(includes EOF marker)</span></div>
    </div>
  </div>
  <div class="col">
    <div class="p-2 border rounded">
      <div class="mb-2"><strong>Readme duplication</strong></div>
      <div class="small text-body-secondary mb-2"><code>NFO</code> = <code>DIZ</code> · The extras contains both UUID.DIZ and UUID.TXT that are identical</div>
      <div><a href="/f/a51daa8" class="{{$fid}}">a51daa8</a></div>
    </div>
  </div>
  <div class="col">
    <div class="p-2 border rounded">
      <div class="mb-2"><strong>Readme with multi-bytes</strong></div>
      <div class="small text-body-secondary mb-2">The UTF-8 file magic must be set to display correctly</div>
      <div>
        <a href="/f/b12d05f" class="{{$fid}}">b12d05f</a> · <a href="/f/b228a8e" class="{{$fid}}">b228a8e</a> · 
        <a href="/f/b53028e" class="{{$fid}}">b53028e</a>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="p-2 border rounded">
      <div class="mb-2 d-flex gap-2 align-items-center"><strong>Unknown or corrupt encodings</strong> {{$confirmed}}</div>
