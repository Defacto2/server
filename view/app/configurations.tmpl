    </div>
  </div>
  <div class="col">
    <div class="p-2 border rounded">
      <div class="mb-2"><strong>Readme duplicate FILE_ID.DIZ</strong></div>
      <div class="small text-body-secondary mb-2">Duplicate file ID entries</div>
      <div><a href="/f/ab232a7" class="{{$fid}}">ab232a7</a> · <a href="/f/b53028e" class="{{$fid}}">b53028e</a></div>
    </div>
  </div>
  <div class="col">
    <div class="p-2 border rounded">
      <div class="mb-2"><strong>Code Page 437</strong></div>
      <div class="small text-body-secondary mb-2">Textfiles encoded in the IBM PC character set</div>
      <div>
        <a href="/f/ab2f2b4" class="{{$fid}}">ab2f2b4</a> · <a href="/f/ba2db9e" class="{{$fid}}">ba2db9e</a> · 
        <a href="/f/ab43cb" class="{{$fid}}">ab43cb</a> · <a href="/f/b42ccd8" class="{{$fid}}">b42ccd8</a> · 
        <a href="/f/af2c260" class="{{$fid}}">af2c260</a>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="p-2 border rounded">
      <div class="mb-2"><strong>ISO 8859-1</strong></div>
      <div class="small text-body-secondary mb-2">Textfiles encoded in the Latin-1 character set</div>
      <div>
        <a href="/f/a5191c3" class="{{$fid}}">a5191c3</a> · <a href="/f/ab1fc8b" class="{{$fid}}">ab1fc8b</a> · 
