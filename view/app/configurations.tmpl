      <div><a href="/f/b02ecf1" class="{{$fid}}">b02ecf1</a></div>
    </div>
  </div>
  <div class="col">
    <div class="p-2 border rounded">
      <div class="mb-2"><strong>Readme requires wrapping</strong></div>
      <div class="small text-body-secondary mb-2">Text that needs line wrapping</div>
      <div>
        <a href="/f/b14bb1" class="{{$fid}}">b14bb1</a> · <a href="/f/b12fe37" class="{{$fid}}">b12fe37</a> · 
