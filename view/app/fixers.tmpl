{{- /* 
    fixers.tmpl ~ Fixers page template.
*/ -}}
{{- define "content" }}
    <h2 class="lead mt-5">Files with Numeric Suffixes</h2>
    <p>These files have numeric suffixes like <code>(1)</code>, <code>(2)</code>, etc. that may need cleaning up.</p>
    {{ if .numericSuffixCount }}
    <div class="card mb-4">
        <div class="card-header">
            <strong>{{ .numericSuffixCount }}</strong> files found
        </div>
        <div class="card-body">
            <div class="list-group">
                {{ range .numericSuffixFiles }}
                <div class="list-group-item">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <code>{{ .Filename }}</code>
                            <small class="text-muted d-block">
                                ID: {{ .ID }} | UUID: {{ .UUID }}
                            </small>
                        </div>
                        <div>
                            <a href="/f/{{ .ObfuscatedID }}" class="btn btn-sm btn-outline-secondary" target="_blank">View</a>
                            <button class="btn btn-sm btn-outline-danger ms-1" hx-post="/editor/fixers/fix/{{ .ObfuscatedID }}" hx-target="closest .list-group-item" hx-swap="outerHTML">Fix</button>
                        </div>
                    </div>
                </div>
                {{ end }}
            </div>
        </div>
    </div>
    {{ else }}
    <div class="alert alert-info">No files with numeric suffixes found.</div>
    {{ end }}
{{- end}}
