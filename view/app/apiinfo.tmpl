{{- /* 
  Milestone API endpoints table 
*/ -}}
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h2 class="h5 mb-0">Milestone API endpoints</h2>
                </div>
                <div class="card-body">
                    <div class="table-responsive mb-4">
