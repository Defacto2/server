                                    <th>Endpoint</th>
                                    <th>Method</th>
                                    <th>Description</th>
                                    <th>Example</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><code>/boards</code></td>
                                    <td><span class="badge bg-success">GET</span></td>
                                    <td>Get all BBS boards</td>
                                    <td><code>GET {{$api}}boards</code></td>
                                </tr>
                                <tr>
                                    <td><code>/categories</code></td>
                                    <td><span class="badge bg-success">GET</span></td>
                                    <td>Get all artifact categories</td>
                                    <td><code>GET {{$api}}categories</code></td>
                                </tr>
                                <tr>
                                    <td><code>/websites</code></td>
                                    <td><span class="badge bg-success">GET</span></td>
                                    <td>Get all curated websites <span class="text-secondary">(alphabetical)</span></td>
                                    <td><code>GET {{$api}}websites</code></td>
                                </tr>
                                <tr>
                                    <td><code>/demozoo</code></td>
                                    <td><span class="badge bg-success">GET</span></td>
                                    <td>Get all Demozoo group mappings</td>
                                    <td><code>GET {{$api}}demozoo</code></td>
                                </tr>
                                <tr>
                                    <td><code>/groups</code></td>
