{{- /* 
    apiinfo.tmpl ~ API helper template.
*/ -}}
{{- define "content" }}
{{- $baseUrl := "https://defacto2.net/api/v0"}}
{{- $api := "/api/v0/"}}
<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h2 class="h5 mb-0">Base URL</h2>
                </div>
                <div class="card-body">
                    <div class="input-group mb-3">
                        <input type="text" class="form-control" id="baseUrl" value="{{$baseUrl}}" readonly>
                        <button class="btn btn-outline-secondary" type="button" onclick="copyToClipboard('baseUrl')">Copy</button>
                    </div>
                    <p>The base URL for all API endpoints.</p>
                    <p class="text-muted">Examples:</p>
                      <ul>
                        <li><a href="{{$api}}files">{{$baseUrl}}/files</a></li>
                        <li><a href="{{$api}}files/new">{{$baseUrl}}/files/new</a></li>
                        <li><a href="{{$api}}categories">{{$baseUrl}}/categories</a></li>
                        <li><a href="{{$api}}category/releaseadvert">{{$baseUrl}}/category/releaseadvert</a></li>
                        <li><a href="{{$api}}magazines">{{$baseUrl}}/magazines</a></li>
                        <li><a href="{{$api}}releaser/razor-1911">{{$baseUrl}}/releaser/razor-1911</a></li>
                        <li><a href="{{$api}}milestones/year/1971">{{$baseUrl}}/milestones/year/1971</a></li>
                        <li><a href="{{$api}}areacodes/territories/CA">{{$baseUrl}}/areacodes/territories/CA</a></li>
                        <li><a href="{{$api}}sceners/artist">{{$baseUrl}}/sceners/artist</a></li>
                        <li><a href="{{$api}}scener/dubmood">{{$baseUrl}}/scener/dubmood</a></li>
                        <li><a href="{{$api}}websites">{{$baseUrl}}/websites</a></li>
                        <li><a href="{{$api}}demozoo">{{$baseUrl}}/demozoo</a></li>
                      </ul>
                    </p>
                    <p>No authentication is required for read-only API endpoints.</p>
                    <div class="alert alert-success" role="alert">
                      15-May-2025, More API features will be rolled out soon, and the API base uri is temporary: <code>/api/v0</code>
                    </div>
                </div>
            </div>
            {{- /* Base URL for all endpoints table */ -}}
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h2 class="h5 mb-0">Endpoints</h2>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
