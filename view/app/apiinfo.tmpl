{{- /* 
    apiinfo.tmpl ~ API helper template.
*/ -}}
{{- define "content" }}
<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h2 class="h5 mb-0">Base URL</h2>
                </div>
                <div class="card-body">
                    <div class="input-group mb-3">
                        <input type="text" class="form-control" id="baseUrl" value="https://defacto2.net/api" readonly>
                        <button class="btn btn-outline-secondary" type="button" onclick="copyToClipboard('baseUrl')">Copy</button>
                    </div>
                    <p>The base URL for all API endpoints.</p>
                    <p class="text-muted">Examples:</p>
                      <ul>
                        <li><a href="/api/categories">https://defacto2.net/api/categories</a></li>
                        <li><a href="/api/category/announcements">https://defacto2.net/api/category/announcements</a>
                        <li><a href="/api/magazines">https://defacto2.net/api/magazines</a></li>
                        <li><a href="/api/releaser/defacto2">https://defacto2.net/api/releaser/defacto2</a>
                        <li><a href="/api/milestones/year/1971">https://defacto2.net/api/milestones/year/1971</a></li>
                        <li><a href="/api/areacodes/territories/CA">https://defacto2.net/api/areacodes/territories/CA</a></li>
                      </ul>
                    </p>
                    <p>No authentication is required for read-only API endpoints.</p>
                    <div class="alert alert-success" role="alert">
                      12-May-2025, More API features will be rolled out soon!
                    </div>
                </div>
            </div>
            {{- /* Base URL for all endpoints table */ -}}
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h2 class="h5 mb-0">Endpoints</h2>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>Endpoint</th>
                                    <th>Method</th>
                                    <th>Description</th>
                                    <th>Example</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><code>/boards</code></td>
                                    <td><span class="badge bg-success">GET</span></td>
                                    <td>Get all BBS boards</td>
                                    <td><code>GET /api/boards</code></td>
                                </tr>
                                <tr>
                                    <td><code>/categories</code></td>
                                    <td><span class="badge bg-success">GET</span></td>
                                    <td>Get all artifact categories</td>
                                    <td><code>GET /api/categories</code></td>
                                </tr>
                                <tr>
                                    <td><code>/groups</code></td>
                                    <td><span class="badge bg-success">GET</span></td>
                                    <td>Get all releaser groups (paginated)</td>
                                    <td><code>GET /api/groups?page=1</code></td>
                                </tr>
                                <tr>
                                    <td><code>/magazines</code></td>
                                    <td><span class="badge bg-success">GET</span></td>
                                    <td>Get all scene magazines</td>
                                    <td><code>GET /api/magazines</code></td>
                                </tr>
                                <tr>
                                    <td><code>/platforms</code></td>
                                    <td><span class="badge bg-success">GET</span></td>
                                    <td>Get all artifact platforms</td>
                                    <td><code>GET /api/platforms</code></td>
                                </tr>
                                <tr>
                                    <td><code>/category/:name</code></td>
                                    <td><span class="badge bg-success">GET</span></td>
                                    <td>Get files from any category<br><span class="text-secondary">(demo, scenerules, magazine, etc.)</span></td>
                                    <td><code>GET /api/category/demo</code></td>
                                </tr>
                                <tr>
                                    <td><code>/platform/:name</code></td>
                                    <td><span class="badge bg-success">GET</span></td>
                                    <td>Get files from any platform<br><span class="text-secondary">(ansi, audio, dos, windows, etc.)</span></td>
                                    <td><code>GET /api/platform/ansi</code></td>
                                </tr>
                                <tr>
                                    <td><code>/releaser/:name</code></td>
                                    <td><span class="badge bg-success">GET</span></td>
                                    <td>Get files from a specific group or magazine</td>
                                    <td><code>GET /api/releaser/razor-1911</code></td>
                                </tr>
                                <tr>
                                    <td><code>/milestones</code></td>
                                    <td><span class="badge bg-success">GET</span></td>
                                    <td>Get all milestones</td>
                                    <td><code>GET /api/milestones</code></td>
                                </tr>
                                <tr>
                                    <td><code>/milestones/year/:year</code></td>
                                    <td><span class="badge bg-success">GET</span></td>
                                    <td>Get milestones by specific year</td>
                                    <td><code>GET /api/milestones/year/1995</code></td>
                                </tr>
                                <tr>
                                    <td><code>/milestones/years/:range</code></td>
                                    <td><span class="badge bg-success">GET</span></td>
                                    <td>Get milestones by year range</td>
                                    <td><code>GET /api/milestones/years/1990-2000</code></td>
                                </tr>
                                <tr>
                                    <td><code>/milestones/highlights</code></td>
                                    <td><span class="badge bg-success">GET</span></td>
                                    <td>Get only highlighted milestones</td>
                                    <td><code>GET /api/milestones/highlights</code></td>
                                </tr>
                                <tr>
                                    <td><code>/milestones/decade/:decade</code></td>
                                    <td><span class="badge bg-success">GET</span></td>
                                    <td>Get milestones by decade</td>
                                    <td><code>GET /api/milestones/decade/1990s</code></td>
                                </tr>
                                <tr>
                                    <td><code>/areacodes</code></td>
                                    <td><span class="badge bg-success">GET</span></td>
                                    <td>Get all area codes</td>
                                    <td><code>GET /api/areacodes</code></td>
                                </tr>
                                <tr>
                                    <td><code>/areacodes/:code</code></td>
                                    <td><span class="badge bg-success">GET</span></td>
                                    <td>Get area code by code</td>
                                    <td><code>GET /api/areacodes/212</code></td>
                                </tr>
                                <tr>
                                    <td><code>/areacodes/territories</code></td>
                                    <td><span class="badge bg-success">GET</span></td>
                                    <td>Get all territories</td>
                                    <td><code>GET /api/areacodes/territories</code></td>
                                </tr>
                                <tr>
                                    <td><code>/areacodes/territories/:abbr</code></td>
                                    <td><span class="badge bg-success">GET</span></td>
                                    <td>Get territory by abbreviation</td>
                                    <td><code>GET /api/areacodes/territories/CA</code></td>
                                </tr>
                                <tr>
                                    <td><code>/areacodes/search/:query</code></td>
                                    <td><span class="badge bg-success">GET</span></td>
                                    <td>Search area codes and territories</td>
                                    <td><code>GET /api/areacodes/search/california</code></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
