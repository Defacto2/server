{{- /*
    interview.tmpl ~ Generates the content for the people interviews page.
*/ -}}
{{- define "content" -}}
<div class="mb-5 text-center">
    This list of interviews and discussions is incomplete, and some of these interviews are amateur and cringe.
</div>
<div class="container mt-4">
    <div class="row justify-content-md-center row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    {{- range $relIndex, $releaser := .interviews }}
      {{- range $index, $interview := $releaser.Interviews }}
      <div class="col">
        <div class="card h-100 shadow-sm rounded-3 border-0">
            <div class="card-body">
                <h5 class="card-title text-center fw-bold mb-2">{{$interview.Scener}}</h5>    
                <h6 class="card-subtitle mb-3 text-muted text-center fs-6">
                  {{- if ne $releaser.Link ""}}{{$releaser.Name}} • {{end}}{{$interview.Year}} {{fmtMonth $interview.Month}}
                </h6>
                <p class="card-text">{{$interview.Content}}</p>
            </div>
            <div class="card-footer text-center pt-3 border-top">
                <a href="{{$interview.Link}}" class="icon-link icon-link-hover fw-medium">Read the interview {{linkInterview $interview.Link}}</a> 
            </div>
          </div>
      </div>
      {{- end}}
    {{- end}}
    </div>
  </div>
{{- end -}}
