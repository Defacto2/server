    <div class="col">
        <div class="card{{$cardClass}}">
            <div class="card-body">
                <h5 class="card-title">Publish dates</h5>
                <div class="fs-6">
                    <div class="mb-3 pb-2 border-bottom">
                        <span class="fw-light">Overall</span> {{$rels.Record.MinYear}} - {{$rels.Record.MaxYear}}
                    </div>
                    <div class="lh-lg" style="font-size: 0.95rem;">
                        <div><span class="fw-light">ansi art</span> {{$rels.Ansi.MinYear}}-{{$rels.Ansi.MaxYear}}</div>
                        <div><span class="fw-light">BBS adverts</span> {{$rels.BBS.MinYear}}-{{$rels.BBS.MaxYear}}</div>
                        <div><span class="fw-light">cracktros and intros</span> {{$rels.Intro.MinYear}}-{{$rels.Intro.MaxYear}}</div>
                        <div><span class="fw-light">Java files</span> {{$rels.Java.MinYear}}-{{$rels.Java.MaxYear}}</div>
                        <div><span class="fw-light">Linux files</span> {{$rels.Linux.MinYear}}-{{$rels.Linux.MaxYear}}</div>
                        <div><span class="fw-light">magazines</span> {{$rels.Magazine.MinYear}}-{{$rels.Magazine.MaxYear}}</div>
                        <div><span class="fw-light">MacOS files</span> {{$rels.Macos.MinYear}}-{{$rels.Macos.MaxYear}}</div>
                        <div><span class="fw-light">{{msdos}} files</span> {{$rels.MsDos.MinYear}}-{{$rels.MsDos.MaxYear}}</div>
                        <div><span class="fw-light">nfo texts</span> {{$rels.Nfo.MinYear}}-{{$rels.Nfo.MaxYear}}</div>
                        <div><span class="fw-light">scripts</span> {{$rels.Script.MinYear}}-{{$rels.Script.MaxYear}}</div>
                        <div><span class="fw-light">text files</span> {{$rels.Text.MinYear}}-{{$rels.Text.MaxYear}}</div>
