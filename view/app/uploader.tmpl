{{- /* 
    uploader.tmpl ~ About the uploader modal dialog.
*/ -}}
{{- define "uploader" -}} 
    <div class="modal fade" id="uploader-about" tabindex="-1" aria-labelledby="uploader-about-label" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="uploader-about-label">About the Uploader</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <p>
              Do you have any Scene files that Defacto2 could use? You can use our Uploader to send us files we should host. 
              A person manually approves all uploads, which may take time to be available on the site.
              <u>But no inappropriate files or modern programs that break the <abbr title="Digital Millennium Copyright Act">DMCA</abbr></u>.
            </p>
            <p><a href="https://github.com/Defacto2/defacto2.net/wiki/Wanted-uploads">Check out the wanted files</a>.</p>
            <p>There is a 100MB per file upload limit. Please <a href="#contacts-email-modal" data-bs-toggle="modal" data-bs-target="#contacts-email-modal">contact us</a> if you need access to an SFTP server to bypass this limit.</p>
            <hr>
            <h6 class="text-muted mb-2">Keyboard shortcuts <small class="fw-normal">(ctrl + alt +)</small></h6>
          <div class="row g-3">
            <div class="col-6">
              <dl class="mb-0">
                <div class="d-inline-block me-3">
                  <dt class="d-inline"><kbd>d</kbd></dt>
                  <dd class="d-inline mb-2"><small> intro for DOS</small></dd>
                </div>
                <div class="d-inline-block me-3">
                  <dt class="d-inline"><kbd>w</kbd></dt>
                  <dd class="d-inline mb-2"><small> intro for Windows</small></dd>
                </div>
                <div class="d-inline-block me-3">
                  <dt class="d-inline"><kbd>b</kbd></dt>
                  <dd class="d-inline mb-2"><small> bbstro (bbs intro)</small></dd>
                </div>
                <div class="d-inline-block me-3">
                  <dt class="d-inline"><kbd>c</kbd></dt>
                  <dd class="d-inline mb-2"><small> intro or cracktro</small></dd>
                </div>
                <div class="d-inline-block me-3">
                  <dt class="d-inline"><kbd>t</kbd></dt>
                  <dd class="d-inline mb-2"><small> trainer or game hack app</small></dd>
                </div>
                <div class="d-inline-block me-3">
                  <dt class="d-inline"><kbd>i</kbd></dt>
                  <dd class="d-inline mb-2"><small> installer app</small></dd>
                </div>
                <div class="d-inline-block pt-2">
                  <dt class="d-inline"><kbd class="small"><small>⌫</small></kbd></dt>
                  <dd class="d-inline"><small> backspace, to close uploader</small></dd>
                </div>
              </dl>
            </div>
            <div class="col-6">
              <dl class="mb-0">
                <div class="d-inline-block me-3">
                  <dt class="d-inline"><kbd>n</kbd></dt>
                  <dd class="d-inline mb-2"><small> nfo, ansi, diz, text</small></dd>
                </div>
                <div class="d-inline-block me-3">
                  <dt class="d-inline"><kbd>p</kbd></dt>
                  <dd class="d-inline mb-2"><small> photo, picture or image art</small></dd>
                </div>
                <div class="d-inline-block me-3">
                  <dt class="d-inline"><kbd>m</kbd></dt>
                  <dd class="d-inline mb-2"><small> magazines</small></dd>
                </div>
                <div class="d-inline-block me-3">
                  <dt class="d-inline"><kbd>a</kbd></dt>
                  <dd class="d-inline mb-2"><small> advance uploader</small></dd>
                </div>
                <div class="d-inline-block">
                  <dt class="d-inline"><kbd>z</kbd></dt>
                  <dd class="d-inline"><small> demozoo production</small></dd>
                </div>
              </dl>
            </div>
          </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
          </div>
        </div>
      </div>
    </div>
{{- end -}}
